# Claude Code Environment Variables Template
# Copy this file to .env and fill in your actual values
# The .env file should never be committed to version control

# Required: Your Anthropic API token for Claude access
# Get this from: https://console.anthropic.com/account/keys
ANTHROPIC_AUTH_TOKEN=your_anthropic_auth_token_here

# Optional: Custom API base URL if using a proxy or alternative endpoint
# Default: https://api.anthropic.com
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: API timeout in milliseconds
# Default: 60000 (60 seconds)
API_TIMEOUT_MS=60000

# Optional: Disable non-essential traffic for privacy
# Set to 1 to disable, 0 to enable (default: 0)
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=0

# Setup Instructions:
# 1. Copy this template: cp .env.template .env
# 2. Edit .env with your actual values
# 3. The .env file is automatically ignored by git
# 4. Restart Claude Code to load the new environment variables