#!/usr/bin/env bash
# Quick image viewer using kitty

if [ $# -eq 0 ]; then
    echo "Usage: kitty-img <image_file> [options]"
    echo "Options:"
    echo "  --center    Center the image"
    echo "  --fit       Fit image to terminal"
    echo "  --thumb     Show thumbnail"
    exit 1
fi

image_file="$1"
shift

if [ ! -f "$image_file" ]; then
    echo "Error: File '$image_file' not found"
    exit 1
fi

case "$1" in
    --center)
        kitty +kitten icat --align=center "$image_file"
        ;;
    --fit)
        kitty +kitten icat --place=$(tput cols)x$(tput lines)@0x0 "$image_file"
        ;;
    --thumb)
        kitty +kitten icat --place=20x10@0x0 "$image_file"
        ;;
    *)
        kitty +kitten icat "$image_file"
        ;;
esac