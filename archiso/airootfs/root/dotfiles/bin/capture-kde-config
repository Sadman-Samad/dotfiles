#!/usr/bin/env bash

# Capture Current KDE Configuration Script
# Captures your current KDE Plasma and Krohnkite configuration to dotfiles

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
KDE_CONFIG_DIR="$DOTFILES_DIR/kde/.config"

print_usage() {
    echo "Capture Current KDE Configuration"
    echo
    echo "Usage: $0 [options]"
    echo
    echo "Options:"
    echo "  --backup-first    Create backup of existing dotfiles config"
    echo "  --shortcuts-only  Only capture shortcuts, not other KDE configs"
    echo "  --dry-run        Show what would be captured without doing it"
    echo "  --force          Overwrite existing config files without prompting"
    echo
    echo "This script captures your current KDE configuration and saves it to"
    echo "the dotfiles kde/ package so it can be restored on new installations."
    echo
    echo "Configuration files captured:"
    echo "  - Global shortcuts (kglobalshortcutsrc)"
    echo "  - KWin settings (kwinrc)"
    echo "  - Window rules (kwinrulesrc)" 
    echo "  - Plasma layout (plasma-org.kde.plasma.desktop-appletsrc)"
    echo "  - KRunner settings (krunnerrc)"
    echo "  - Other KDE configuration files"
}

check_environment() {
    if [ "$XDG_CURRENT_DESKTOP" != "KDE" ]; then
        print_error "Not running KDE Plasma desktop environment"
        print_info "Current desktop: ${XDG_CURRENT_DESKTOP:-none}"
        return 1
    fi
    
    if [ ! -d "$HOME/.config" ]; then
        print_error "KDE config directory not found: $HOME/.config"
        return 1
    fi
    
    # Check if we're in the dotfiles directory
    if [ ! -f "$DOTFILES_DIR/CLAUDE.md" ]; then
        print_error "Not running from dotfiles directory or CLAUDE.md not found"
        print_info "Expected dotfiles directory: $DOTFILES_DIR"
        return 1
    fi
    
    print_success "Environment check passed"
    return 0
}

backup_existing_config() {
    if [ ! -d "$KDE_CONFIG_DIR" ]; then
        print_info "No existing KDE config to backup"
        return 0
    fi
    
    local backup_dir="$DOTFILES_DIR/kde-config-backup-$(date +%Y%m%d-%H%M%S)"
    print_info "Creating backup of existing dotfiles KDE config..."
    
    cp -r "$KDE_CONFIG_DIR" "$backup_dir"
    print_success "Backup created: $backup_dir"
}

capture_config_file() {
    local source_file="$1"
    local dest_file="$2"
    local description="$3"
    local dry_run="$4"
    
    if [ ! -f "$source_file" ]; then
        print_warning "Source file not found: $source_file"
        return 1
    fi
    
    if [ "$dry_run" = true ]; then
        echo "[DRY-RUN] Would copy: $source_file -> $dest_file ($description)"
        return 0
    fi
    
    # Create destination directory if needed
    mkdir -p "$(dirname "$dest_file")"
    
    # Check if destination exists and get user confirmation
    if [ -f "$dest_file" ] && [ "$FORCE_OVERWRITE" != true ]; then
        print_warning "Destination file exists: $dest_file"
        read -p "Overwrite? (y/N): " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            print_info "Skipped: $description"
            return 0
        fi
    fi
    
    # Copy the file
    if cp "$source_file" "$dest_file"; then
        print_success "Captured: $description"
        
        # Show file size and modification time
        local size=$(stat -f%z "$dest_file" 2>/dev/null || stat -c%s "$dest_file" 2>/dev/null || echo "unknown")
        local mtime=$(stat -f%Sm "$dest_file" 2>/dev/null || stat -c%y "$dest_file" 2>/dev/null || echo "unknown")
        print_info "  Size: ${size} bytes, Modified: ${mtime}"
    else
        print_error "Failed to copy: $source_file"
        return 1
    fi
    
    return 0
}

capture_kde_configs() {
    local shortcuts_only="$1" 
    local dry_run="$2"
    
    print_info "Capturing KDE configuration files..."
    echo
    
    # Essential KDE configuration files to capture
    local config_files=(
        # Core shortcut and window management
        "$HOME/.config/kglobalshortcutsrc:$KDE_CONFIG_DIR/kglobalshortcutsrc:Global shortcuts"
        "$HOME/.config/kwinrc:$KDE_CONFIG_DIR/kwinrc:KWin window manager settings"
        "$HOME/.config/kwinrulesrc:$KDE_CONFIG_DIR/kwinrulesrc:Window rules"
    )
    
    # Additional configs (skip if shortcuts-only)
    if [ "$shortcuts_only" != true ]; then
        config_files+=(
            "$HOME/.config/plasma-org.kde.plasma.desktop-appletsrc:$KDE_CONFIG_DIR/plasma-org.kde.plasma.desktop-appletsrc:Plasma desktop layout"
            "$HOME/.config/krunnerrc:$KDE_CONFIG_DIR/krunnerrc:KRunner launcher settings"
            "$HOME/.config/kded5rc:$KDE_CONFIG_DIR/kded5rc:KDE daemon settings"
            "$HOME/.config/ksmserverrc:$KDE_CONFIG_DIR/ksmserverrc:Session manager settings"
            "$HOME/.config/khotkeysrc:$KDE_CONFIG_DIR/khotkeysrc:Custom hotkeys"
            "$HOME/.config/kdeglobals:$KDE_CONFIG_DIR/kdeglobals:Global KDE settings"
            "$HOME/.config/plasmarc:$KDE_CONFIG_DIR/plasmarc:Plasma shell settings"
        )
    fi
    
    local captured_count=0
    local total_count=${#config_files[@]}
    
    # Process each configuration file
    for config_entry in "${config_files[@]}"; do
        IFS=':' read -r source_path dest_path description <<< "$config_entry"
        
        if capture_config_file "$source_path" "$dest_path" "$description" "$dry_run"; then
            ((captured_count++))
        fi
    done
    
    echo
    print_success "Configuration capture completed: $captured_count/$total_count files"
    
    # Show summary of what was captured
    if [ "$dry_run" != true ] && [ $captured_count -gt 0 ]; then
        echo
        print_info "Captured files summary:"
        find "$KDE_CONFIG_DIR" -type f -name "*.rc" -o -name "*.conf" -o -name "*appletsrc" -o -name "kdeglobals" | while read -r file; do
            local relative_path="${file#$KDE_CONFIG_DIR/}"
            local size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo "?")
            printf "  %-40s %8s bytes\n" "$relative_path" "$size"
        done
    fi
}

create_current_shortcuts_preset() {
    local dry_run="$1"
    local preset_file="$DOTFILES_DIR/kde/shortcuts-presets.conf"
    
    if [ "$dry_run" = true ]; then
        echo "[DRY-RUN] Would create 'current-system' preset in shortcuts-presets.conf"
        return 0
    fi
    
    print_info "Creating 'current-system' preset from your shortcuts..."
    
    # Check if kglobalshortcutsrc exists
    if [ ! -f "$HOME/.config/kglobalshortcutsrc" ]; then
        print_error "Global shortcuts file not found: $HOME/.config/kglobalshortcutsrc"
        return 1
    fi
    
    # Create temporary preset content
    local temp_preset=$(mktemp)
    
    {
        echo ""
        echo "# Current System Configuration - Auto-generated on $(date)"
        echo "[current-system]"
        
        # Extract Krohnkite shortcuts from kwin section
        local in_kwin_section=false
        while IFS= read -r line; do
            if [[ $line =~ ^\[kwin\]$ ]]; then
                in_kwin_section=true
                continue
            elif [[ $line =~ ^\[.*\]$ ]]; then
                in_kwin_section=false
                continue
            fi
            
            if [ "$in_kwin_section" = true ] && [[ $line =~ ^([^=]+)=([^,]*), ]]; then
                local action="${BASH_REMATCH[1]}"
                local shortcut="${BASH_REMATCH[2]}"
                
                # Filter for important shortcuts (window management and Krohnkite)
                if [[ $action =~ (Window|toggle_|set_master|focus_|push_window_|_master_|next_layout|prev_layout|rotate|Overview|Desktop) ]] && [ "$shortcut" != "none" ] && [ -n "$shortcut" ]; then
                    echo "${action}=${shortcut}"
                fi
            fi
        done < "$HOME/.config/kglobalshortcutsrc"
        
    } > "$temp_preset"
    
    # Append to presets file or create it
    if [ -f "$preset_file" ]; then
        # Remove existing current-system section if it exists
        awk '
        BEGIN { in_current_system = 0; skip = 0 }
        /^\[current-system\]$/ { skip = 1; next }
        /^\[.*\]$/ && skip == 1 { skip = 0 }
        skip == 0 { print }
        ' "$preset_file" > "$preset_file.tmp"
        
        # Append new preset
        cat "$preset_file.tmp" "$temp_preset" > "$preset_file"
        rm "$preset_file.tmp"
    else
        cp "$temp_preset" "$preset_file"
    fi
    
    rm "$temp_preset"
    
    print_success "Created 'current-system' preset in shortcuts-presets.conf"
    print_info "You can now apply it with: bin/apply-shortcuts-preset current-system"
}

update_stow_scripts() {
    local dry_run="$1"
    
    # Check if kde is already in stow scripts
    if grep -q "kde" "$DOTFILES_DIR/stowup" 2>/dev/null; then
        print_info "KDE package already included in stow scripts"
        return 0
    fi
    
    if [ "$dry_run" = true ]; then
        echo "[DRY-RUN] Would add 'kde' to stowup and stowDown scripts"
        return 0
    fi
    
    print_info "Adding kde package to stow management scripts..."
    
    # This should already be done, but check just in case
    if [ -f "$DOTFILES_DIR/stowup" ]; then
        print_success "Stow scripts already configured for KDE"
    else
        print_warning "Stow scripts not found or need manual update"
    fi
}

validate_captured_config() {
    print_info "Validating captured configuration..."
    
    local issues=0
    
    # Check essential files
    local essential_files=(
        "$KDE_CONFIG_DIR/kglobalshortcutsrc"
        "$KDE_CONFIG_DIR/kwinrc"
    )
    
    for file in "${essential_files[@]}"; do
        if [ -f "$file" ]; then
            local size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
            if [ "$size" -gt 100 ]; then
                print_success "✓ $(basename "$file") - ${size} bytes"
            else
                print_warning "⚠ $(basename "$file") seems too small - ${size} bytes"
                ((issues++))
            fi
        else
            print_error "✗ Missing: $(basename "$file")"
            ((issues++))
        fi
    done
    
    # Check for Krohnkite configuration
    if [ -f "$KDE_CONFIG_DIR/kwinrc" ]; then
        if grep -q "krohnkiteEnabled=true" "$KDE_CONFIG_DIR/kwinrc"; then
            print_success "✓ Krohnkite configuration detected"
        else
            print_warning "⚠ Krohnkite not enabled in captured kwinrc"
        fi
    fi
    
    # Check shortcuts
    if [ -f "$KDE_CONFIG_DIR/kglobalshortcutsrc" ]; then
        local shortcut_count=$(grep -c "^[^#\[].*=" "$KDE_CONFIG_DIR/kglobalshortcutsrc" || echo 0)
        print_info "Captured $shortcut_count global shortcuts"
    fi
    
    if [ $issues -eq 0 ]; then
        print_success "Configuration validation completed successfully"
    else
        print_warning "Validation completed with $issues issues"
    fi
}

main() {
    local backup_first=false
    local shortcuts_only=false
    local dry_run=false
    local force_overwrite=false
    
    # Parse command line arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            --backup-first)
                backup_first=true
                shift
                ;;
            --shortcuts-only)
                shortcuts_only=true
                shift
                ;;
            --dry-run)
                dry_run=true
                shift
                ;;
            --force)
                force_overwrite=true
                shift
                ;;
            --help|-h)
                print_usage
                return 0
                ;;
            *)
                print_error "Unknown option: $1"
                print_usage
                return 1
                ;;
        esac
    done
    
    # Export force flag for use in functions
    export FORCE_OVERWRITE=$force_overwrite
    
    echo "KDE Configuration Capture Tool"
    echo "=============================="
    echo
    
    # Environment checks
    if ! check_environment; then
        return 1
    fi
    
    # Show what will be captured
    print_info "Dotfiles directory: $DOTFILES_DIR"
    print_info "Target directory: $KDE_CONFIG_DIR"
    
    if [ "$shortcuts_only" = true ]; then
        print_info "Mode: Shortcuts only"
    else
        print_info "Mode: Full KDE configuration"
    fi
    
    if [ "$dry_run" = true ]; then
        print_warning "DRY-RUN MODE - No files will be modified"
    fi
    
    echo
    
    # Create backup if requested
    if [ "$backup_first" = true ]; then
        backup_existing_config
    fi
    
    # Capture configuration
    capture_kde_configs "$shortcuts_only" "$dry_run"
    
    # Create current-system preset
    create_current_shortcuts_preset "$dry_run"
    
    # Update stow scripts
    update_stow_scripts "$dry_run"
    
    # Validate what was captured
    if [ "$dry_run" != true ]; then
        echo
        validate_captured_config
    fi
    
    # Final instructions
    echo
    if [ "$dry_run" = true ]; then
        print_info "This was a dry-run. Use without --dry-run to actually capture configuration."
    else
        print_success "KDE configuration capture completed!"
        echo
        print_info "Next steps:"
        echo "1. Review captured files in: kde/.config/"
        echo "2. Test configuration: stow kde"
        echo "3. Apply shortcuts: bin/apply-shortcuts-preset current-system"
        echo "4. Commit changes: git add kde/ && git commit -m 'Update KDE configuration'"
        echo
        print_info "To restore on new system:"
        echo "1. Clone dotfiles repository"
        echo "2. Run: ./install.sh"
        echo "3. Or manually: stow kde && bin/setup-krohnkite"
    fi
}

main "$@"