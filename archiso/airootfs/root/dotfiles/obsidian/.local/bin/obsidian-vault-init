#!/usr/bin/env bash

# obsidian-vault-init - Initialize a new Obsidian vault with dotfiles configuration
# Usage: obsidian-vault-init <vault-name> <type> [vault-path]
#   vault-name: Name of the vault (e.g., vault-personal)
#   type: personal, work, public, or project
#   vault-path: Optional custom path (defaults to ~/Documents/<vault-name>)

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"
OBSIDIAN_CONFIG_DIR="$DOTFILES_DIR/obsidian/.config/obsidian"
DEFAULT_VAULT_DIR="$HOME/Documents"

# Helper functions
print_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

usage() {
    cat <<EOF
Usage: obsidian-vault-init <vault-name> <type> [vault-path]

Initialize a new Obsidian vault with configuration from dotfiles.

Arguments:
  vault-name    Name of the vault (e.g., vault-personal, vault-work)
  type          Vault type: personal, work, public, or project
  vault-path    Optional custom path (default: ~/Documents/<vault-name>)

Types:
  personal      Personal notes and knowledge base (private git repo)
  work          Work-related notes (private/company git repo)
  public        Public documentation/knowledge base (public git repo)
  project       Project-specific documentation (private git repo)

Examples:
  obsidian-vault-init vault-personal personal
  obsidian-vault-init vault-work work
  obsidian-vault-init vault-public public ~/Projects/public-kb
  obsidian-vault-init my-project project ~/Projects/my-project/docs

EOF
}

# Validate arguments
if [[ $# -lt 2 ]]; then
    usage
    exit 1
fi

VAULT_NAME="$1"
VAULT_TYPE="$2"
VAULT_PATH="${3:-$DEFAULT_VAULT_DIR/$VAULT_NAME}"

# Validate vault type
case "$VAULT_TYPE" in
    personal|work|public|project)
        ;;
    *)
        print_error "Invalid vault type: $VAULT_TYPE"
        echo "Valid types: personal, work, public, project"
        exit 1
        ;;
esac

# Check if dotfiles obsidian config exists
if [[ ! -d "$OBSIDIAN_CONFIG_DIR" ]]; then
    print_error "Obsidian config not found in dotfiles: $OBSIDIAN_CONFIG_DIR"
    echo "Make sure you have stowed the obsidian package: stow -t ~ obsidian"
    exit 1
fi

# Check if vault already exists
if [[ -d "$VAULT_PATH" ]]; then
    print_warning "Vault already exists at: $VAULT_PATH"
    read -p "Do you want to reinitialize it? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Aborted."
        exit 0
    fi
fi

print_info "Initializing Obsidian vault..."
echo "  Name: $VAULT_NAME"
echo "  Type: $VAULT_TYPE"
echo "  Path: $VAULT_PATH"
echo

# Create vault directory
mkdir -p "$VAULT_PATH"
print_success "Created vault directory: $VAULT_PATH"

# Create .obsidian directory
mkdir -p "$VAULT_PATH/.obsidian"

# Copy shared config
print_info "Copying shared Obsidian configuration..."
cp -r "$OBSIDIAN_CONFIG_DIR/shared-config"/* "$VAULT_PATH/.obsidian/"
print_success "Copied shared config"

# Copy type-specific config if exists
TYPE_CONFIG_DIR="$OBSIDIAN_CONFIG_DIR/${VAULT_TYPE}-config"
if [[ -d "$TYPE_CONFIG_DIR" ]] && [[ -n "$(ls -A "$TYPE_CONFIG_DIR" 2>/dev/null | grep -v '.gitignore.template')" ]]; then
    print_info "Copying $VAULT_TYPE-specific configuration..."
    cp -r "$TYPE_CONFIG_DIR"/* "$VAULT_PATH/.obsidian/" 2>/dev/null || true
    print_success "Copied $VAULT_TYPE-specific config"
fi

# Copy .gitignore template
if [[ -f "$TYPE_CONFIG_DIR/.gitignore.template" ]]; then
    cp "$TYPE_CONFIG_DIR/.gitignore.template" "$VAULT_PATH/.gitignore"
    print_success "Copied .gitignore template for $VAULT_TYPE vault"
else
    print_warning "No .gitignore template found for $VAULT_TYPE, using base"
    cp "$OBSIDIAN_CONFIG_DIR/shared-config/.gitignore.base" "$VAULT_PATH/.gitignore"
fi

# Create basic folder structure based on type
print_info "Creating folder structure..."
case "$VAULT_TYPE" in
    personal)
        mkdir -p "$VAULT_PATH"/{Areas,Projects,Resources,Archive,Templates}
        cat > "$VAULT_PATH/README.md" <<'EOFREADME'
# Personal Knowledge Base

## Structure

- **Areas**: Life areas and ongoing responsibilities
- **Projects**: Active personal projects and goals
- **Resources**: Reference materials, articles, bookmarks
- **Archive**: Completed projects and old notes
- **Templates**: Note templates for quick creation

## Quick Start

1. Create your first note
2. Set up daily notes in Settings → Daily notes
3. Explore the graph view to see connections

EOFREADME
        ;;
    work)
        mkdir -p "$VAULT_PATH"/{Projects,Meetings,Documentation,Ideas,Archive,Templates}
        cat > "$VAULT_PATH/README.md" <<'EOFREADME'
# Work Knowledge Base

## Structure

- **Projects**: Work projects and initiatives
- **Meetings**: Meeting notes and action items
- **Documentation**: Technical docs, processes, runbooks
- **Ideas**: Ideas and proposals
- **Archive**: Completed work and old notes
- **Templates**: Templates for meetings, project docs, etc.

## Quick Start

1. Create project folders under Projects/
2. Use Templates for consistent meeting notes
3. Link related notes together

EOFREADME
        ;;
    public)
        mkdir -p "$VAULT_PATH"/{Articles,Guides,Tutorials,References,Templates}
        cat > "$VAULT_PATH/README.md" <<'EOFREADME'
# Public Knowledge Base

Public documentation and knowledge sharing.

## Structure

- **Articles**: Long-form articles and posts
- **Guides**: How-to guides and walkthroughs
- **Tutorials**: Step-by-step tutorials
- **References**: Quick reference materials
- **Templates**: Content templates

## Contributing

This vault is public. Feel free to suggest improvements!

EOFREADME
        ;;
    project)
        mkdir -p "$VAULT_PATH"/{Architecture,ADRs,Meeting-Notes,Tasks,References}
        cat > "$VAULT_PATH/README.md" <<'EOFREADME'
# Project Documentation

Documentation for this project using Obsidian.

## Structure

- **Architecture**: Architecture decisions and diagrams
- **ADRs**: Architecture Decision Records
- **Meeting-Notes**: Project meeting notes
- **Tasks**: Task breakdowns and planning
- **References**: Reference documentation

## Quick Start

1. Document architectural decisions in ADRs/
2. Keep meeting notes organized
3. Link tasks to relevant documentation

EOFREADME
        ;;
esac
print_success "Created folder structure for $VAULT_TYPE vault"

# Initialize git repository
if [[ ! -d "$VAULT_PATH/.git" ]]; then
    print_info "Initializing git repository..."
    cd "$VAULT_PATH"
    git init
    git add .
    git commit -m "Initial commit: Initialize $VAULT_TYPE vault

Created with obsidian-vault-init script from dotfiles."
    print_success "Initialized git repository"

    print_info "Next steps:"
    echo "  1. cd $VAULT_PATH"
    echo "  2. git remote add origin <your-git-repo-url>"
    echo "  3. git push -u origin main"
else
    print_warning "Git repository already exists, skipping initialization"
fi

echo
print_success "Vault initialized successfully!"
echo
echo "Location: $VAULT_PATH"
echo "Type: $VAULT_TYPE"
echo
echo "You can now:"
echo "  • Open the vault in Obsidian"
echo "  • Customize .gitignore to your needs"
echo "  • Add a git remote and push to your repository"
echo "  • Run 'obsidian-sync-config' to sync settings from dotfiles"
