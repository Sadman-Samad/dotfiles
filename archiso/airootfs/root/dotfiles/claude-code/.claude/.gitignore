# Sensitive files - OAuth tokens and credentials
.credentials.json

# Machine-specific data - command and interaction history
history.jsonl

# Debug logs - session-specific debugging information
debug/

# File history - edit history and version tracking
file-history/

# Shell snapshots - command execution history
shell-snapshots/

# Project-specific data - conversation and context per project
projects/

# Task tracking - session-specific todos
todos/

# IDE and editor state
ide/

# Notification settings
ccnotify/

# Session environment variables
session-env/

# Analytics and feature flags
statsig/

# Keep these files (configuration we want to track):
# - settings.json (global settings)
# - commands/ (custom slash commands)
# - hooks/ (event hooks)
# - .mcp.json (global MCP server configuration, if it exists)
