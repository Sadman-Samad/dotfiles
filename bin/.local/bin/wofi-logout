#!/usr/bin/env bash
# wofi-logout — session menu (lock/logout/reboot/shutdown)
# Called via $mainMod SHIFT E

action=$(wofi --dmenu --prompt "Session" --cache-file=/dev/null \
    --location top_right --xoffset 12 --yoffset 48 --lines 4 --width 200 \
    << EOF
  Lock
 Logout
 Reboot
⏻  Shutdown
EOF
)

case "$action" in
    *Lock*)     hyprlock ;;
    *Logout*)   hyprctl dispatch exit ;;
    *Reboot*)   systemctl reboot ;;
    *Shutdown*) systemctl poweroff ;;
esac
