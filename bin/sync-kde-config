#!/usr/bin/env bash

# Sync KDE Configuration Script
# Quick script to capture current config and make it ready for deployment

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

print_usage() {
    echo "Sync KDE Configuration"
    echo
    echo "Usage: $0 [options]"
    echo
    echo "This script captures your current KDE configuration and ensures"
    echo "it will be automatically applied on new installations."
    echo
    echo "Options:"
    echo "  --commit         Auto-commit changes to git"
    echo "  --test-apply     Test applying the captured config"
    echo "  --shortcuts-only Only sync shortcuts, not full KDE config"
    echo
    echo "What this script does:"
    echo "1. Captures your current KDE configuration"
    echo "2. Creates a 'current-system' shortcut preset"
    echo "3. Optionally commits the changes to git"
    echo "4. Optionally tests the configuration"
}

main() {
    local auto_commit=false
    local test_apply=false
    local shortcuts_only=false
    
    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            --commit)
                auto_commit=true
                shift
                ;;
            --test-apply)
                test_apply=true
                shift
                ;;
            --shortcuts-only)
                shortcuts_only=true
                shift
                ;;
            --help|-h)
                print_usage
                return 0
                ;;
            *)
                print_error "Unknown option: $1"
                print_usage
                return 1
                ;;
        esac
    done
    
    echo "KDE Configuration Sync"
    echo "====================="
    echo
    
    # Check environment
    if [ "$XDG_CURRENT_DESKTOP" != "KDE" ]; then
        print_error "Not running KDE Plasma"
        return 1
    fi
    
    # Step 1: Capture current configuration
    print_info "Step 1: Capturing current KDE configuration..."
    local capture_args="--force"
    if [ "$shortcuts_only" = true ]; then
        capture_args="$capture_args --shortcuts-only"
    fi
    
    "$DOTFILES_DIR/bin/capture-kde-config" $capture_args
    
    if [ $? -ne 0 ]; then
        print_error "Failed to capture configuration"
        return 1
    fi
    
    # Step 2: Test applying the configuration (if requested)
    if [ "$test_apply" = true ]; then
        echo
        print_info "Step 2: Testing configuration application..."
        
        if [ -f "$DOTFILES_DIR/kde/shortcuts-presets.conf" ] && grep -q "\[current-system\]" "$DOTFILES_DIR/kde/shortcuts-presets.conf"; then
            print_info "Testing shortcut preset application..."
            "$DOTFILES_DIR/bin/apply-shortcuts-preset" current-system --dry-run
            
            echo
            read -p "Apply shortcuts now for testing? (y/N): " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                "$DOTFILES_DIR/bin/apply-shortcuts-preset" current-system --backup
                print_success "Shortcuts applied with backup"
            fi
        else
            print_warning "No current-system preset found to test"
        fi
    fi
    
    # Step 3: Commit changes (if requested)
    if [ "$auto_commit" = true ]; then
        echo
        print_info "Step 3: Committing changes to git..."
        
        cd "$DOTFILES_DIR"
        
        # Check if there are changes to commit
        if git diff --quiet kde/ 2>/dev/null; then
            print_info "No changes to commit"
        else
            # Add KDE configuration files
            git add kde/
            
            # Create commit message
            local commit_msg="Update KDE configuration - $(date '+%Y-%m-%d %H:%M')"
            if [ "$shortcuts_only" = true ]; then
                commit_msg="Update KDE shortcuts - $(date '+%Y-%m-%d %H:%M')"
            fi
            
            git commit -m "$commit_msg" || true
            print_success "Changes committed to git"
            
            # Show what was committed
            print_info "Committed files:"
            git show --name-only --pretty=format: HEAD | grep -E '^kde/' | sed 's/^/  /'
        fi
    fi
    
    # Final summary
    echo
    print_success "KDE configuration sync completed!"
    echo
    print_info "Your current configuration is now saved in the dotfiles."
    echo "It will be automatically applied when you run:"
    echo "  ./install.sh                    # Full installation"
    echo "  stow kde                        # Apply KDE config only"
    echo "  bin/setup-krohnkite             # Setup Krohnkite only"
    echo
    
    if [ -f "$DOTFILES_DIR/kde/shortcuts-presets.conf" ] && grep -q "\[current-system\]" "$DOTFILES_DIR/kde/shortcuts-presets.conf"; then
        print_info "You can also manually apply shortcuts with:"
        echo "  bin/apply-shortcuts-preset current-system"
    fi
    
    if [ "$auto_commit" != true ]; then
        print_info "To save changes permanently, run:"
        echo "  git add kde/ && git commit -m 'Update KDE configuration'"
    fi
}

main "$@"