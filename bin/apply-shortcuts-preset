#!/usr/bin/env bash

# Apply KDE Shortcuts Preset Script
# Quickly apply predefined shortcut configurations

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PRESETS_FILE="$DOTFILES_DIR/kde/shortcuts-presets.conf"
KDE_SHORTCUTS_SCRIPT="$DOTFILES_DIR/bin/kde-shortcuts"

print_usage() {
    echo "Apply KDE Shortcuts Preset"
    echo
    echo "Usage: $0 <preset-name> [options]"
    echo
    echo "Available presets:"
    if [ -f "$PRESETS_FILE" ]; then
        echo "$(grep -E '^\[.*\]$' "$PRESETS_FILE" | sed 's/\[\(.*\)\]/  \1/')"
    else
        echo "  No presets file found at: $PRESETS_FILE"
    fi
    echo
    echo "Options:"
    echo "  --dry-run       Show what would be changed without applying"
    echo "  --backup        Create backup before applying changes"
    echo "  --list          List all available presets with descriptions"
    echo
    echo "Examples:"
    echo "  $0 krohnkite-default                    # Apply default Krohnkite shortcuts"
    echo "  $0 developer-focused --backup           # Apply developer shortcuts with backup"
    echo "  $0 gaming-minimal --dry-run            # Preview gaming shortcuts"
    echo "  $0 --list                              # List all available presets"
}

list_presets() {
    if [ ! -f "$PRESETS_FILE" ]; then
        print_error "Presets file not found: $PRESETS_FILE"
        return 1
    fi
    
    echo "Available KDE Shortcut Presets:"
    echo "==============================="
    echo
    
    local current_preset=""
    local description=""
    
    while IFS= read -r line; do
        if [[ $line =~ ^\[(.+)\]$ ]]; then
            # New preset section
            if [ -n "$current_preset" ]; then
                printf "%-20s %s\n" "$current_preset" "$description"
            fi
            current_preset="${BASH_REMATCH[1]}"
            description=""
        elif [[ $line =~ ^#\ (.+)$ ]] && [ -z "$description" ]; then
            # Description comment (first comment after preset header)
            description="${BASH_REMATCH[1]}"
        fi
    done < "$PRESETS_FILE"
    
    # Print last preset
    if [ -n "$current_preset" ]; then
        printf "%-20s %s\n" "$current_preset" "$description"
    fi
}

parse_preset() {
    local preset_name="$1"
    local in_section=false
    local shortcuts=()
    
    if [ ! -f "$PRESETS_FILE" ]; then
        print_error "Presets file not found: $PRESETS_FILE"
        return 1
    fi
    
    while IFS= read -r line; do
        if [[ $line =~ ^\[(.+)\]$ ]]; then
            local section="${BASH_REMATCH[1]}"
            if [ "$section" = "$preset_name" ]; then
                in_section=true
                continue
            else
                in_section=false
            fi
        fi
        
        if [ "$in_section" = true ] && [[ $line =~ ^([^=]+)=(.+)$ ]]; then
            local action="${BASH_REMATCH[1]}"
            local shortcut="${BASH_REMATCH[2]}"
            shortcuts+=("$action:$shortcut")
        fi
    done < "$PRESETS_FILE"
    
    if [ ${#shortcuts[@]} -eq 0 ]; then
        print_error "Preset '$preset_name' not found or has no shortcuts"
        return 1
    fi
    
    # Return shortcuts array (print to stdout for capture)
    printf '%s\n' "${shortcuts[@]}"
    return 0
}

determine_component() {
    local action="$1"
    
    # Map actions to KDE components
    case "$action" in
        toggle_tile|toggle_float|set_master|next_layout|prev_layout|rotate|rotate_part|\
        focus_*|push_window_*|*_master_*)
            echo "kwin"
            ;;
        Window\ *|Switch\ to\ Desktop\ *|Overview|ShowDesktopGrid|Walk\ Through\ *)
            echo "kwin"
            ;;
        org.kde.*)
            echo "plasmashell"
            ;;
        media_*|volume_*)
            echo "kmix"
            ;;
        *)
            # Default to kwin for most window management actions
            echo "kwin"
            ;;
    esac
}

apply_preset() {
    local preset_name="$1"
    local dry_run="$2"
    local create_backup="$3"
    
    print_info "Applying preset: $preset_name"
    
    # Check if kde-shortcuts script exists
    if [ ! -f "$KDE_SHORTCUTS_SCRIPT" ]; then
        print_error "KDE shortcuts script not found: $KDE_SHORTCUTS_SCRIPT"
        return 1
    fi
    
    # Parse preset
    local shortcuts
    if ! shortcuts=$(parse_preset "$preset_name"); then
        return 1
    fi
    
    # Create backup if requested
    if [ "$create_backup" = true ]; then
        print_info "Creating backup..."
        "$KDE_SHORTCUTS_SCRIPT" backup
    fi
    
    # Apply shortcuts
    local changes_made=false
    while IFS= read -r shortcut_line; do
        if [ -n "$shortcut_line" ]; then
            IFS=':' read -r action shortcut <<< "$shortcut_line"
            local component=$(determine_component "$action")
            
            if [ "$dry_run" = true ]; then
                echo "[DRY-RUN] Would set: $component -> $action = $shortcut"
            else
                print_info "Setting: $component -> $action = $shortcut"
                
                if "$KDE_SHORTCUTS_SCRIPT" set "$component" "$action" "$shortcut" 2>/dev/null; then
                    changes_made=true
                else
                    print_warning "Failed to set: $action = $shortcut"
                fi
            fi
        fi
    done <<< "$shortcuts"
    
    if [ "$dry_run" = false ] && [ "$changes_made" = true ]; then
        print_success "Preset '$preset_name' applied successfully"
        
        # Reload shortcuts
        print_info "Reloading shortcuts configuration..."
        "$KDE_SHORTCUTS_SCRIPT" reload
    elif [ "$dry_run" = true ]; then
        print_info "Dry-run completed. Use without --dry-run to apply changes."
    else
        print_warning "No changes were made"
    fi
}

main() {
    local preset_name=""
    local dry_run=false
    local create_backup=false
    local list_presets_only=false
    
    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run)
                dry_run=true
                shift
                ;;
            --backup)
                create_backup=true
                shift
                ;;
            --list)
                list_presets_only=true
                shift
                ;;
            --help|-h)
                print_usage
                return 0
                ;;
            -*)
                print_error "Unknown option: $1"
                print_usage
                return 1
                ;;
            *)
                if [ -z "$preset_name" ]; then
                    preset_name="$1"
                else
                    print_error "Multiple preset names provided"
                    print_usage
                    return 1
                fi
                shift
                ;;
        esac
    done
    
    # Check KDE environment
    if [ "$XDG_CURRENT_DESKTOP" != "KDE" ]; then
        print_warning "Not running KDE Plasma"
    fi
    
    # Handle list request
    if [ "$list_presets_only" = true ]; then
        list_presets
        return 0
    fi
    
    # Validate preset name
    if [ -z "$preset_name" ]; then
        print_error "No preset name provided"
        print_usage
        return 1
    fi
    
    # Apply preset
    apply_preset "$preset_name" "$dry_run" "$create_backup"
}

main "$@"